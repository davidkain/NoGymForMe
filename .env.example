# ─────────────────────────────────────────────────────────────────────────
# SUMIT payment gateway — DO NOT put real values in this file or commit them.
#
# These are read by api/create-payment.js via process.env. In production set
# them in the Vercel dashboard:  Project → Settings → Environment Variables
# (add for Production AND Preview). For local testing with `vercel dev`,
# copy this file to `.env.local` and fill in real values — `.env.local` is
# git-ignored.
# ─────────────────────────────────────────────────────────────────────────

# Your SUMIT Company ID (numeric). Found in the SUMIT dashboard.
SUMIT_COMPANY_ID=

# Your SUMIT private API key. SUMIT dashboard → settings → API / מפתח API.
# This is the SECRET key — it must never appear in any HTML/JS sent to browsers.
SUMIT_API_KEY=

# Optional: canonical site origin used to build the post-payment return URL,
# e.g. https://www.nogymforme.com . If omitted, the function uses the incoming
# request host (works automatically on Vercel preview + production).
# SITE_URL=

# ─────────────────────────────────────────────────────────────────────────
# Meta Conversions API (CAPI) — read by api/meta-capi-purchase.js.
# Set these on the "nogymforme" Vercel project (Production AND Preview) — NOT on
# the companion "nogymforme_app_claude" tracking app. Never commit real values;
# the token is a SECRET and must never appear in any HTML/JS sent to browsers.
# ─────────────────────────────────────────────────────────────────────────

# Your Meta Pixel / Dataset ID (the same numeric id used by the browser Pixel,
# e.g. the 1001650429062777 in thank-you.html).
META_PIXEL_ID=

# CAPI system-user access token. Events Manager → Settings → Conversions API →
# "Generate access token".
META_CAPI_TOKEN=

# Optional: while verifying, paste the code from Events Manager → Test Events so
# events land in the Test tab instead of your live numbers. REMOVE for production.
# META_TEST_EVENT_CODE=

# Optional overrides (sensible defaults already baked into the route):
# META_GRAPH_VERSION=v21.0
# META_DEFAULT_COUNTRY_CODE=972
# META_PRODUCT_ID=nogymforme-90-capsules
